{
  "name": "memory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "opennextjs-cloudflare build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "clean:opennext": "node -e \"try{require('fs').rmSync('.open-next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "verify": "npm run lint && npm run clean:opennext && npm run build && npx opennextjs-cloudflare deploy --dry-run && npx wrangler deploy -c cloudflare/wrangler.worker.toml --dry-run",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "worker:deploy": "wrangler deploy -c cloudflare/wrangler.worker.toml",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.79.0"
  }
}
